AIVDSE_POLICY_DIR=./policy

# LLM settings
AIVDSE_LLM_PROVIDER=openai         # openai | anthropic
AIVDSE_MODEL_NAME=gpt-4o-mini      # or claude-sonnet-4-20250514 for anthropic
AIVDSE_SDK_MODE=langchain           # langchain | anthropic (direct SDK)
OPENAI_API_KEY=your-key-here
ANTHROPIC_API_KEY=your-key-here     # only needed if provider=anthropic or sdk_mode=anthropic

# Local logging (no external telemetry)
AIVDSE_LOG_LLM_IO=0                # 1 = log prompts/responses locally
AIVDSE_LLM_LOG_DIR=./out/debug_llm

# Langfuse tracing (optional observability)
AIVDSE_USE_LANGFUSE=0              # 1 = enable Langfuse tracing
LANGFUSE_SECRET_KEY=sk-lf-...      # Langfuse secret key
LANGFUSE_PUBLIC_KEY=pk-lf-...      # Langfuse public key
LANGFUSE_HOST=https://cloud.langfuse.com  # Or self-hosted URL
